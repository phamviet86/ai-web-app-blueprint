{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/phamviet86/ai-web-app-blueprint/main/docs/presets/preset.schema.json",
  "title": "AI Web App Blueprint preset manifest",
  "description": "Machine-checkable v1.1 shape for preset.json. Repository validation additionally resolves paths, names, declared skills, the verification command registry, cross-file contracts, and SHA-256 values.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "preset_id",
    "preset_version",
    "blueprint_version",
    "blueprint_revision",
    "status",
    "archetype",
    "stack",
    "capabilities",
    "verified_flows",
    "materialization",
    "skills",
    "patterns",
    "sources",
    "design",
    "verification"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "schema_version": { "const": "1.1.0" },
    "preset_id": { "$ref": "#/$defs/presetId" },
    "preset_version": { "$ref": "#/$defs/version" },
    "blueprint_version": { "$ref": "#/$defs/version" },
    "blueprint_revision": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
    "status": {
      "enum": ["experimental", "candidate", "verified", "deprecated", "retired"]
    },
    "archetype": { "$ref": "#/$defs/kebabId" },
    "stack": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/stackItem" }
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          { "$ref": "#/$defs/kebabId" },
          { "$ref": "#/$defs/capability" }
        ]
      }
    },
    "verified_flows": {
      "type": "array",
      "items": {
        "oneOf": [
          { "$ref": "#/$defs/kebabId" },
          { "$ref": "#/$defs/verifiedFlow" }
        ]
      }
    },
    "materialization": {
      "oneOf": [
        {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "oneOf": [
              { "$ref": "#/$defs/relativePath" },
              { "$ref": "#/$defs/materializationEntry" }
            ]
          }
        },
        {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/materializationEntry" }
        }
      ]
    },
    "skills": {
      "type": "object",
      "propertyNames": { "$ref": "#/$defs/kebabId" },
      "additionalProperties": { "$ref": "#/$defs/skill" },
      "required": ["analyze-request", "lib", "shared", "feature", "app", "new-pattern", "ui"],
      "properties": {
        "analyze-request": { "$ref": "#/$defs/skill" },
        "lib": { "$ref": "#/$defs/skill" },
        "shared": { "$ref": "#/$defs/skill" },
        "feature": { "$ref": "#/$defs/skill" },
        "app": { "$ref": "#/$defs/skill" },
        "new-pattern": { "$ref": "#/$defs/skill" },
        "ui": { "$ref": "#/$defs/skill" },
        "audit-changes": { "$ref": "#/$defs/skill" },
        "publish": { "$ref": "#/$defs/skill" }
      }
    },
    "patterns": {
      "type": "object",
      "additionalProperties": false,
      "required": ["catalog", "sha256"],
      "properties": {
        "catalog": { "const": "patterns/catalog.json" },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "sources": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ledger", "sha256"],
      "properties": {
        "ledger": { "$ref": "#/$defs/relativePath" },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commands", "skill_evals"],
      "properties": {
        "commands": { "$ref": "#/$defs/digestedFile" },
        "skill_evals": { "$ref": "#/$defs/fileReference" },
        "integrity": { "$ref": "#/$defs/fileReference" },
        "clean_room_evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/fileReference" }
        },
        "independent_use_evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/digestedFile" }
        }
      }
    },
    "design": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contract", "sha256", "evidence"],
      "properties": {
        "contract": { "$ref": "#/$defs/relativePath" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/fileReference" }
        }
      }
    },
    "prerequisites": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hard", "quality"],
      "properties": {
        "hard": { "type": "array", "items": { "$ref": "#/$defs/prerequisite" } },
        "quality": { "type": "array", "items": { "$ref": "#/$defs/qualityPrerequisite" } }
      }
    },
    "compatibility": {
      "type": "array",
      "items": { "$ref": "#/$defs/compatibility" }
    },
    "upgrade_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "breaking_change_policy", "stale_after_days"],
      "properties": {
        "strategy": { "const": "explicit-merge" },
        "breaking_change_policy": { "const": "require-decision" },
        "stale_after_days": { "type": "integer", "minimum": 1 }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "status": { "enum": ["candidate", "verified"] } },
        "required": ["status"]
      },
      "then": {
        "required": ["upgrade_policy"],
        "properties": {
          "capabilities": {
            "items": { "$ref": "#/$defs/capability" }
          },
          "verified_flows": {
            "minItems": 1,
            "items": { "$ref": "#/$defs/verifiedFlow" }
          },
          "verification": {
            "required": ["commands", "skill_evals", "integrity", "clean_room_evidence"],
            "properties": {
              "commands": { "$ref": "#/$defs/digestedFile" },
              "skill_evals": { "$ref": "#/$defs/digestedFile" },
              "integrity": { "$ref": "#/$defs/digestedFile" },
              "clean_room_evidence": {
                "minItems": 1,
                "items": { "$ref": "#/$defs/digestedFile" }
              }
            }
          },
          "design": {
            "properties": {
              "evidence": {
                "minItems": 1,
                "items": { "$ref": "#/$defs/digestedFile" }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": { "status": { "const": "verified" } },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "verification": {
            "required": ["independent_use_evidence"],
            "properties": {
              "independent_use_evidence": {
                "minItems": 1,
                "items": { "$ref": "#/$defs/digestedFile" }
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "kebabId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "maxLength": 96
    },
    "presetId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "maxLength": 47
    },
    "skillName": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "maxLength": 63
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*:)(?!.*\\\\)(?!.*[. ](?:/|$))(?!.*(?:^|/)(?:\\.\\.?|)(?:/|$)).+$"
    },
    "nonEmptyStrings": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "stackItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["package", "version", "source_id"],
      "properties": {
        "package": { "type": "string", "minLength": 1 },
        "version": { "$ref": "#/$defs/version" },
        "source_id": { "$ref": "#/$defs/kebabId" }
      }
    },
    "capability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "status", "providers", "consumers", "payloads", "states", "constraints", "patterns", "evidence"],
      "properties": {
        "id": { "$ref": "#/$defs/kebabId" },
        "status": { "enum": ["provided", "verified", "conditional", "unsupported"] },
        "providers": { "type": "array", "items": { "type": "string" } },
        "consumers": { "type": "array", "items": { "type": "string" } },
        "payloads": { "type": "array", "items": { "type": "string" } },
        "states": { "type": "array", "items": { "type": "string" } },
        "constraints": { "type": "array", "items": { "type": "string" } },
        "patterns": { "$ref": "#/$defs/nonEmptyStrings" },
        "evidence": { "type": "array", "items": { "$ref": "#/$defs/fileReference" } }
      }
    },
    "verifiedFlow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "capability_id", "steps", "evidence"],
      "properties": {
        "id": { "$ref": "#/$defs/kebabId" },
        "capability_id": { "$ref": "#/$defs/kebabId" },
        "steps": { "$ref": "#/$defs/nonEmptyStrings" },
        "evidence": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/fileReference" } }
      }
    },
    "materializationEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "target", "operation", "conflict_policy", "sha256"],
      "properties": {
        "source": { "$ref": "#/$defs/relativePath" },
        "target": { "$ref": "#/$defs/relativePath" },
        "operation": { "enum": ["create", "merge", "replace"] },
        "conflict_policy": { "enum": ["fail", "require-decision", "verified-merge"] },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "invocation": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        { "$ref": "#/$defs/nonEmptyStrings" },
        {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "type": "string", "minLength": 1 }
        }
      ]
    },
    "skill": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "path", "sha256", "invocation", "targets"],
      "properties": {
        "name": { "$ref": "#/$defs/skillName" },
        "path": { "type": "string", "pattern": "^guides/[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "invocation": { "$ref": "#/$defs/invocation" },
        "targets": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/kebabId" }
        }
      }
    },
    "digestedFile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": { "$ref": "#/$defs/relativePath" },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "fileReference": {
      "oneOf": [
        { "$ref": "#/$defs/relativePath" },
        { "$ref": "#/$defs/digestedFile" }
      ]
    },
    "prerequisite": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "check", "recovery"],
      "properties": {
        "id": { "$ref": "#/$defs/kebabId" },
        "check": { "type": "string", "minLength": 1 },
        "recovery": { "type": "string", "minLength": 1 },
        "fallback": { "type": "string", "minLength": 1 }
      }
    },
    "qualityPrerequisite": {
      "allOf": [
        { "$ref": "#/$defs/prerequisite" },
        { "required": ["fallback"] }
      ]
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["subject", "range", "status", "evidence"],
      "properties": {
        "subject": { "type": "string", "minLength": 1 },
        "range": { "type": "string", "minLength": 1 },
        "status": { "enum": ["supported", "conditional", "unsupported"] },
        "evidence": { "type": "array", "items": { "$ref": "#/$defs/fileReference" } }
      }
    }
  }
}

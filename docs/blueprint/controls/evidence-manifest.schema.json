{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Readiness evidence manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_id",
    "manifest_version",
    "assessment_id",
    "source_revision",
    "target",
    "environment",
    "records"
  ],
  "properties": {
    "manifest_id": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9]*(?:-[A-Z0-9]+){2,}$"
    },
    "manifest_version": {
      "const": "1.0.0"
    },
    "assessment_id": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9]*(?:-[A-Z0-9]+){2,}$"
    },
    "source_revision": {
      "type": "string",
      "minLength": 1
    },
    "target": {
      "type": "string",
      "minLength": 1
    },
    "environment": {
      "type": "string",
      "minLength": 1
    },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "reference",
          "artifact",
          "sha256",
          "result",
          "producer",
          "observed_at"
        ],
        "properties": {
          "reference": {
            "type": "string",
            "pattern": "^(command|test|artifact|measurement|drill|runtime|review|planning):\\S.+$"
          },
          "artifact": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "result": {
            "const": "pass"
          },
          "producer": {
            "type": "string",
            "minLength": 1
          },
          "observed_at": {
            "type": "string",
            "format": "date"
          }
        }
      }
    }
  }
}

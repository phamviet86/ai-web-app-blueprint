{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/phamviet86/ai-web-app-blueprint/main/docs/blueprint/schemas/verification-command-registry.schema.json",
  "title": "AI Web App Blueprint governed-app verification command registry",
  "description": "Portable, argv-based command lanes executed during preset or app-profile clean-room verification.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "lanes"],
  "properties": {
    "$schema": { "type": "string", "minLength": 1 },
    "schema_version": { "const": "1.0.0" },
    "lanes": {
      "type": "object",
      "required": ["install", "doctor", "test", "check", "build", "start-smoke"],
      "propertyNames": {
        "allOf": [
          { "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
          { "not": { "enum": ["publish", "release", "deploy"] } }
        ]
      },
      "additionalProperties": { "$ref": "#/$defs/command" },
      "properties": {
        "install": { "$ref": "#/$defs/command" },
        "doctor": { "$ref": "#/$defs/command" },
        "test": { "$ref": "#/$defs/command" },
        "check": { "$ref": "#/$defs/command" },
        "build": { "$ref": "#/$defs/command" },
        "start-smoke": {
          "allOf": [
            { "$ref": "#/$defs/command" },
            { "required": ["timeout_seconds"] }
          ]
        }
      }
    }
  },
  "$defs": {
    "command": {
      "type": "object",
      "additionalProperties": false,
      "required": ["argv"],
      "properties": {
        "argv": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "cwd": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?:\\.|(?!/)(?!.*:)(?!.*\\\\)(?!.*[. ](?:/|$))(?!.*(?:^|/)(?:\\.\\.?|)(?:/|$)).+)$"
        },
        "required_environment": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_]*$" }
        },
        "timeout_seconds": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
